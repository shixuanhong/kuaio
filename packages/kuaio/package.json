{
  "name": "kuaio",
  "author": {
    "name": "shixuanhong"
  },
  "description": "A modern shortcut JavaScript library.",
  "version": "0.0.4",
  "keywords": [
    "kuaio",
    "shortcut",
    "keyboard",
    "hotkey",
    "keybinding",
    "dom",
    "browser",
    "electron",
    "mousetrap"
  ],
  "license": "MIT",
  "homepage": "https://github.com/shixuanhong/kuaio#readme",
  "bugs": {
    "url": "https://github.com/shixuanhong/kuaio/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/shixuanhong/kuaio.git"
  },
  "type": "module",
  "scripts": {
    "dev": "rollup -c --watch",
    "build": "rimraf dist && rollup -c",
    "publish:lib": "pnpm build && npm publish",
    "test": "vitest"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/kuaio.esm.js",
      "require": "./dist/kuaio.cjs.js",
      "default": "./dist/kuaio.esm.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/kuaio.cjs.js",
  "module": "./dist/kuaio.esm.js",
  "types": "./dist/index.d.ts",
  "devDependencies": {
    "@rollup/plugin-terser": "^0.4.3",
    "@rollup/plugin-typescript": "^11.1.6",
    "jsdom": "^24.0.0",
    "rimraf": "^6.1.3",
    "rollup": "^3.26.2",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3",
    "vitest": "^1.2.2"
  },
  "packageManager": "pnpm@8.0.0+"
}
